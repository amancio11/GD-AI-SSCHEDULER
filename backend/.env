# ── Database (PostgreSQL locale) ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://scheduler:scheduler@localhost:5432/scheduler

# ── Redis (broker Celery) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic AI ──────────────────────────────────────────────────────────────
# Inserire la propria API key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-INSERISCI_QUI_LA_TUA_CHIAVE

# ── Solver CP-SAT ─────────────────────────────────────────────────────────────
CPSAT_TIMEOUT_SECONDS=60
MIN_OP_DURATION_MINUTES=30

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
